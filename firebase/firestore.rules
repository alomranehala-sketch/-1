rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ──────────────────────────────────────────
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function hasRole(role) {
      return isAuthenticated() && request.auth.token.role == role;
    }
    
    function isAdmin() {
      return hasRole('admin') || hasRole('moh_admin');
    }
    
    function isDoctor() {
      return hasRole('doctor');
    }
    
    function isHealthcareStaff() {
      return isDoctor() || hasRole('nurse') || hasRole('pharmacist');
    }

    // ─── Users Collection ──────────────────────────────────────────
    // Users can read their own profile. Admins can read/write all.
    // No client-side writes — all mutations go through Cloud Functions.
    
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if false; // Server-side only (Cloud Functions)
    }

    // ─── Sessions Collection ───────────────────────────────────────
    // Users can read their own sessions. No direct writes.
    
    match /sessions/{sessionId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if false; // Server-side only
    }

    // ─── Audit Logs ────────────────────────────────────────────────
    // Only admins can read. No client writes.
    
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Server-side only
    }

    // ─── Rate Limits ───────────────────────────────────────────────
    // Internal only. No client access.
    
    match /rate_limits/{docId} {
      allow read, write: if false; // Server-side only
    }

    // ─── Intrusion Events ──────────────────────────────────────────
    // Only admins can read for the dashboard.
    
    match /intrusion_events/{eventId} {
      allow read: if isAdmin();
      allow write: if false; // Server-side only
    }

    // ─── Default: Deny All ─────────────────────────────────────────
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
